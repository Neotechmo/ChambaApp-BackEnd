{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,

    // ── Calidad TypeScript (checklist 2.2) ──────────────────────────────
    "strict": true,                        // habilita todo el grupo strict
    "noImplicitAny": true,                 // sin tipos implícitos any
    "strictNullChecks": true,              // manejo explícito de null/undefined
    "noUnusedLocals": true,                // variables locales sin uso → error
    "noUnusedParameters": true,            // parámetros sin uso → error
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true
  }
}
