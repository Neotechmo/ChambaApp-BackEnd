{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../src",
  "testRegex": ".*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/$1"
  },
  "testEnvironment": "node",
  "testTimeout": 60000,
  "globalSetup": "../test/global-setup.ts",
  "globalTeardown": "../test/global-teardown.ts"
}
